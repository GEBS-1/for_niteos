# Скопируйте в .env.local:  copy .env.example .env.local



# --- RouterAI (рекомендуется, оплата в ₽): https://routerai.ru ---

OPENAI_API_KEY=sk-ваш-ключ-routerai

OPENAI_BASE_URL=https://routerai.ru/api/v1



# --- GateLLM (альтернатива): https://gatellm.ru ---

# OPENAI_API_KEY=sk-ваш-ключ

# OPENAI_BASE_URL=https://gatellm.ru/v1



AI_IMAGE_PROVIDER=openai

OPENAI_IMAGE_MODEL=openai/gpt-5-image



USE_LOCAL_RENDERER_ONLY=false

ALLOW_LOCAL_FALLBACK=true



# Этап 1: детекция facadeBox + mountLines (Vision API)

AI_ANALYZE_FACADE=true

AI_VISION_MODEL=openai/gpt-4o-mini



# Этап 4: улучшение света поверх локальной визуализации

AI_ENHANCE_LIGHT=false

OPENAI_TIMEOUT_MS=180000



# Просмотр воронки лидов: GET /api/leads?token=... или страница /admin/leads

LEADS_VIEW_TOKEN=ваш-секретный-токен

