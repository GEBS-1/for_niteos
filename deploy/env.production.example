# Скопируйте на сервер как .env.production (рядом с package.json)
# Docker: те же переменные в .env.production — docker compose их подхватит

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# --- RouterAI (рекомендуется) ---
OPENAI_API_KEY=sk-ВАШ-КЛЮЧ
OPENAI_BASE_URL=https://routerai.ru/api/v1
AI_IMAGE_PROVIDER=openai
OPENAI_IMAGE_MODEL=google/gemini-2.5-flash-image

AI_ANALYZE_FACADE=true
AI_VISION_MODEL=openai/gpt-4o-mini
AI_ENHANCE_LIGHT=false
USE_LOCAL_RENDERER_ONLY=false
ALLOW_LOCAL_FALLBACK=true
OPENAI_TIMEOUT_MS=180000

# --- Воронка лидов и админка (обязательно в production) ---
LEADS_VIEW_TOKEN=замените-на-длинный-случайный-секрет

# --- Рассылка Gmail ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info.test.svet@gmail.com
SMTP_PASS=пароль-приложения-16-символов
SMTP_FROM=info.test.svet@gmail.com
CAMPAIGN_BASE_URL=http://194.226.187.101:3000

# --- Опционально: базовый URL если приложение в подпапке ---
